# Orion — Environment Configuration
# Copy this file to .env and adjust as needed.
#
# Quick start (Docker):
#   cp .env.example .env
#   docker compose up -d --build
#   docker compose logs orion
#
# Open http://127.0.0.1:7000/login — the first admin password is printed in the logs.

# ============================================================
# App (Docker)
# ============================================================

# Host bind address and port for the Orion chat app.
# Keep APP_BIND on loopback unless you intentionally want LAN access.
APP_BIND=127.0.0.1
APP_PORT=7000

# Persistent data directory (auth secrets, runtime config)
APP_DATA_DIR=./data

# Pull the default Ollama model on first boot (true | false)
ORION_PULL_MODEL=true

# ============================================================
# Auth
# ============================================================

# Optional: pre-seed admin credentials before first boot.
# If ORION_ADMIN_PASSWORD is blank, a random password is generated and logged.
ORION_ADMIN_USER=admin
# ORION_ADMIN_PASSWORD=

# Used by native dev in chat/.env.local (Docker generates these automatically):
# APP_USERNAME=admin
# APP_PASSWORD=
# AUTH_SECRET=

# ============================================================
# AI Provider
# ============================================================

AI_PROVIDER=ollama

# Optional system prompt
# ORION_SYSTEM_PROMPT=You are Orion, a helpful local AI assistant.

# Ollama (bundled in Docker Compose)
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL is set automatically in Docker to http://ollama:11434

# OpenAI
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
