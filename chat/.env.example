# Login credentials for local development (npm run dev)
# For Docker, use the root .env file instead — credentials are auto-generated on first boot.
APP_USERNAME=orion
APP_PASSWORD=orion
AUTH_SECRET=generate-a-long-random-secret

# Default provider: ollama | openai | anthropic | google
AI_PROVIDER=ollama

# Optional system prompt
# ORION_SYSTEM_PROMPT=You are Orion, a helpful local AI assistant.

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
